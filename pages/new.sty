<script>
/* ── CURSOR ── */
const cDot=document.getElementById('cDot'),cRing=document.getElementById('cRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cDot.style.left=mx+'px';cDot.style.top=my+'px';});
(function ra(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;cRing.style.left=rx+'px';cRing.style.top=ry+'px';requestAnimationFrame(ra);})();
document.querySelectorAll('a,button,.p-card,.sk-card,.t-card,.b-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cRing.style.width='54px';cRing.style.height='54px';cRing.style.borderColor='var(--accent)';cDot.style.transform='translate(-50%,-50%) scale(2)';});
  el.addEventListener('mouseleave',()=>{cRing.style.width='36px';cRing.style.height='36px';cRing.style.borderColor='rgba(232,255,74,.4)';cDot.style.transform='translate(-50%,-50%) scale(1)';});
});

/* ── PARTICLES ── */
const can=document.getElementById('pts'),ctx=can.getContext('2d');
let W,H,pts=[];
function rsz(){W=can.width=can.offsetWidth;H=can.height=can.offsetHeight;}
rsz();window.addEventListener('resize',rsz);
for(let i=0;i<180;i++) pts.push({x:Math.random()*9999,y:Math.random()*9999,z:Math.random()*800+50,vz:-(Math.random()*.4+.15),h:[65,185,300][~~(Math.random()*3)],r:Math.random()*1.6+.3});
let sp=0;
(function draw(){
  ctx.clearRect(0,0,W,H);
  const spd=1+sp*10;
  for(const p of pts){
    p.z+=p.vz*spd;
    if(p.z<=0){p.z=900;p.x=Math.random()*W;p.y=Math.random()*H;}
    const sc=900/p.z,sx=(p.x-W/2)*sc+W/2,sy=(p.y-H/2)*sc+H/2,sr=p.r*sc;
    const a=Math.min(1,(900-p.z)/700)*(.16+sp*.55);
    ctx.beginPath();ctx.arc(sx,sy,sr,0,Math.PI*2);ctx.fillStyle=`hsla(${p.h},90%,70%,${a})`;ctx.fill();
    if(spd>2.5){const ps=900/(p.z+spd*4),px=(p.x-W/2)*ps+W/2,py=(p.y-H/2)*ps+H/2;
      ctx.beginPath();ctx.moveTo(sx,sy);ctx.lineTo(px,py);ctx.strokeStyle=`hsla(${p.h},90%,70%,${a*.25})`;ctx.lineWidth=sr*.5;ctx.stroke();}
  }
  requestAnimationFrame(draw);
})();

/* ── 3D SCROLL ── */
const heroSec=document.getElementById('heroSec'),heroTxt=document.getElementById('heroTxt'),ccW=document.getElementById('ccW');
const cubeW=document.getElementById('cubeW'),pyrW=document.getElementById('pyrW'),torW=document.getElementById('torW'),icoW=document.getElementById('icoW'),octaW=document.getElementById('octaW');
const or1=document.getElementById('or1'),or2=document.getElementById('or2'),or3=document.getElementById('or3');
const hudV=document.getElementById('hudV'),hudF=document.getElementById('hudF'),hud=document.getElementById('hud');

function L(a,b,t){return a+(b-a)*t;}
function eO(t){return 1-Math.pow(1-t,3);}
function eI(t){return t*t*t;}
function eIO(t){return t<.5?4*t*t*t:1-Math.pow(-2*t+2,3)/2;}
function cl(v,a,b){return Math.max(a,Math.min(b,v));}
function ph(p,a,b){return cl((p-a)/(b-a),0,1);}

function fEl(el,bL,bT,dX,dY,dZ,sF,sT,fi,fo){
  const fp=ph(sP,fi,fo);
  const ex=L(0,dX,eO(fp)),ey=L(0,dY,eO(fp)),ez=L(dZ,0,eO(fp)),esc=L(sF,sT,eO(fp));
  const eop=cl(ph(sP,fi,fi+.08)*8,0,1)*L(1,0,ph(sP,fo-.05,fo));
  el.style.position='absolute';el.style.left=bL;el.style.top=bT;
  el.style.transform=`translate(${ex}px,${ey}px) translateZ(${ez}px) scale(${esc})`;
  el.style.opacity=eop;
}

let sP=0;
function onSc(){
  const r=heroSec.getBoundingClientRect(),sH=heroSec.offsetHeight-window.innerHeight;
  sP=cl(-r.top/sH,0,1); sp=sP;
  hudV.textContent=Math.round(sP*100)+'%';hudF.style.width=(sP*100)+'%';
  hud.style.opacity=sP>0&&sP<1?'1':'.25';

  const p1=ph(sP,0,.22),p2=ph(sP,.22,.52),p3=ph(sP,.52,.72),p4=ph(sP,.72,1);
  const tY=L(300,0,eO(p1))*(1-eI(p4))+L(0,-120,eI(p4));
  const tZ=L(-700,0,eO(p1))+L(0,80,Math.sin(p2*Math.PI))+L(0,-900,eI(p4));
  const rX=L(55,0,eO(p1))+L(0,20,Math.sin(p3*Math.PI))+L(0,-45,p4);
  const rY=L(-35,0,eO(p1))+L(0,360,eIO(p2))+L(0,45,p3);
  const sc=L(.4,1,eO(p1))*L(1,1.1,Math.sin(p2*Math.PI))*L(1,.08,eI(p4));
  const op=cl(p1*6,0,1)*(p4<.7?1:L(1,0,(p4-.7)/.3));
  ccW.style.transform=`translateY(${tY}px) translateZ(${tZ}px) rotateX(${rX}deg) rotateY(${rY}deg) scale(${sc})`;
  ccW.style.opacity=op;

  heroTxt.style.opacity=sP<.08?1:Math.max(0,1-(sP-.08)/.18);
  heroTxt.style.transform=`translateY(${sP*-60}px)`;

  fEl(cubeW,'7%','12%',90,-150,-250,.3,1.4,0,.92);
  fEl(pyrW,'8%','68%',80,-200,-200,.3,1.2,.05,.93);
  fEl(torW,'76%','10%',-110,130,-200,.3,1.2,.08,.94);
  fEl(icoW,'76%','65%',-100,-160,-180,.3,1.1,.12,.95);
  fEl(octaW,'3%','42%',120,60,-220,.2,1.0,.18,.90);

  const oSc=1+sP*1.6,oOp=sP<.12?sP/.12:sP>.88?1-(sP-.88)/.12:1;
  or1.style.transform=`rotateX(75deg) rotateZ(${sP*360}deg) scale(${oSc})`;
  or2.style.transform=`rotateX(70deg) rotateZ(${-sP*360}deg) scale(${oSc*1.1})`;
  or3.style.transform=`rotateX(65deg) rotateZ(${sP*720}deg) scale(${oSc*.7})`;
  or1.style.opacity=oOp*.65;or2.style.opacity=oOp*.45;or3.style.opacity=oOp*.85;
}
window.addEventListener('scroll',onSc,{passive:true});
window.addEventListener('resize',onSc);
onSc();

/* ── SCROLL REVEAL ── */
const io=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target);}});},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* ── CONTRIBUTION GRID ── */
const cg=document.getElementById('cgrid');
const lvls=[0,0,0,1,1,2,2,3,4];
const cols=['rgba(255,255,255,.04)','rgba(232,255,74,.12)','rgba(232,255,74,.32)','rgba(232,255,74,.58)','rgba(232,255,74,.88)'];
for(let r=0;r<7;r++){const row=document.createElement('div');row.className='contrib-row';for(let c=0;c<52;c++){const cell=document.createElement('div');cell.className='contrib-cell';cell.style.background=cols[lvls[~~(Math.random()*lvls.length)]];row.appendChild(cell);}cg.appendChild(row);}

/* ── FORM ── */
function fSub(e){e.preventDefault();const b=document.getElementById('fBtn');b.textContent='Message Sent ✓';b.style.background='rgba(74,240,255,.15)';b.style.color='var(--cyan)';b.style.border='1px solid var(--cyan)';setTimeout(()=>{b.textContent='Send Message →';b.removeAttribute('style');},3000);}

/* ── NAV ACTIVE ── */
const secs=document.querySelectorAll('section[id]'),nls=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{let cur='';secs.forEach(s=>{if(window.scrollY>=s.offsetTop-200)cur=s.id;});nls.forEach(a=>{a.style.color=a.getAttribute('href')==='#'+cur?'var(--accent)':'';});},{passive:true});
</script>
</body>
