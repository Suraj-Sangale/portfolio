<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alex Rivera — Full-Stack Developer</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#05050c; --bg2:#080810; --surface:#0f0f1e;
  --border:rgba(255,255,255,.07);
  --accent:#e8ff4a; --cyan:#4af0ff; --pink:#ff4af0;
  --text:#e8e5de; --muted:rgba(232,229,222,.42);
  --ff-head:'Bebas Neue',cursive;
  --ff-body:'Syne',sans-serif;
  --ff-mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--ff-body);overflow-x:hidden;cursor:none;}
a{color:inherit;text-decoration:none;}

/* SCROLLBAR */
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px;}

/* GRID BG */
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(232,255,74,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(232,255,74,.02) 1px,transparent 1px);background-size:72px 72px;pointer-events:none;z-index:0;}

/* CURSOR */
.cur-dot{position:fixed;top:0;left:0;width:8px;height:8px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s,height .18s,transform .1s;}
.cur-ring{position:fixed;top:0;left:0;width:36px;height:36px;border:1.5px solid rgba(232,255,74,.4);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .2s,height .2s,border-color .2s;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.2rem 4rem;display:flex;align-items:center;justify-content:space-between;background:linear-gradient(to bottom,rgba(5,5,12,.96),transparent);backdrop-filter:blur(14px);border-bottom:1px solid rgba(232,255,74,.05);}
.nav-logo{font-family:var(--ff-head);font-size:1.7rem;letter-spacing:.05em;color:var(--accent);}
.nav-logo span{color:var(--text);opacity:.4;}
.nav-links{display:flex;gap:2.5rem;list-style:none;}
.nav-links a{font-family:var(--ff-mono);font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;color:var(--muted);transition:color .2s;}
.nav-links a:hover,.nav-links a.active{color:var(--accent);}
.nav-cta{font-family:var(--ff-mono);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;padding:.55rem 1.4rem;border:1px solid var(--accent);color:var(--accent);border-radius:3px;transition:background .2s,color .2s;}
.nav-cta:hover{background:var(--accent);color:var(--bg);}

/* SECTION UTILS */
section{position:relative;z-index:1;}
.container{max-width:1180px;margin:0 auto;padding:0 4rem;}
.sec-label{font-family:var(--ff-mono);font-size:.62rem;letter-spacing:.4em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;display:block;}
.sec-title{font-family:var(--ff-head);font-size:clamp(2.8rem,5vw,5.5rem);letter-spacing:.04em;line-height:.95;margin-bottom:3rem;}
.sec-title em{font-style:normal;color:var(--accent);}

/* REVEAL */
.reveal{opacity:0;transform:translateY(38px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}.d4{transition-delay:.4s;}

/* ══════════ HERO ══════════ */
.hero-sec{min-height:500vh;position:relative;}
.hero-sticky{position:sticky;top:0;height:100vh;display:flex;align-items:center;justify-content:center;perspective:1100px;overflow:hidden;}
canvas#pts{position:absolute;inset:0;pointer-events:none;z-index:0;}

.o-ring{position:absolute;border-radius:50%;border-style:solid;pointer-events:none;will-change:transform;}
.or1{width:340px;height:340px;border:1px solid rgba(74,240,255,.1);border-top-color:rgba(74,240,255,.42);}
.or2{width:520px;height:520px;border:1px solid rgba(232,255,74,.06);border-right-color:rgba(232,255,74,.28);}
.or3{width:205px;height:205px;border:1px solid rgba(255,74,240,.08);border-bottom-color:rgba(255,74,240,.38);}

.sw{position:absolute;transform-style:preserve-3d;will-change:transform;}

/* cube */
.css-cube{width:110px;height:110px;transform-style:preserve-3d;animation:cSpin 9s linear infinite;}
@keyframes cSpin{to{transform:rotateX(20deg) rotateY(360deg);}}
.cface{position:absolute;width:110px;height:110px;border:1.5px solid rgba(232,255,74,.5);background:rgba(232,255,74,.04);}
.cface::after{content:'';position:absolute;inset:8px;border:1px solid rgba(232,255,74,.15);}
.cf1{transform:translateZ(55px);background:rgba(232,255,74,.07);}
.cf2{transform:rotateY(180deg) translateZ(55px);}
.cf3{transform:rotateY(-90deg) translateZ(55px);}
.cf4{transform:rotateY(90deg) translateZ(55px);}
.cf5{transform:rotateX(90deg) translateZ(55px);background:rgba(232,255,74,.09);}
.cf6{transform:rotateX(-90deg) translateZ(55px);}

/* pyramid */
.pyr{width:80px;height:80px;position:relative;transform-style:preserve-3d;animation:pSpin 11s linear infinite reverse;}
@keyframes pSpin{to{transform:rotateY(360deg) rotateX(10deg);}}
.pf{position:absolute;width:0;height:0;border-left:40px solid transparent;border-right:40px solid transparent;border-bottom:70px solid rgba(74,240,255,.14);transform-origin:40px 70px;}
.pf:nth-child(1){transform:rotateY(0deg)   translateZ(22px) rotateX(-30deg);border-bottom-color:rgba(74,240,255,.18);}
.pf:nth-child(2){transform:rotateY(90deg)  translateZ(22px) rotateX(-30deg);border-bottom-color:rgba(74,240,255,.12);}
.pf:nth-child(3){transform:rotateY(180deg) translateZ(22px) rotateX(-30deg);border-bottom-color:rgba(74,240,255,.15);}
.pf:nth-child(4){transform:rotateY(270deg) translateZ(22px) rotateX(-30deg);border-bottom-color:rgba(74,240,255,.10);}
.pb{position:absolute;width:56px;height:56px;background:rgba(74,240,255,.05);border:1px solid rgba(74,240,255,.38);transform:rotateX(90deg) translateZ(-10px) translate(-28px,-28px);}

/* torus */
.torus-svg{width:160px;height:160px;animation:tSpin 6s linear infinite;filter:drop-shadow(0 0 10px rgba(255,74,240,.45));}
@keyframes tSpin{to{transform:rotateX(75deg) rotateZ(360deg);}}

/* ico */
.ico-svg{width:130px;height:130px;animation:iSpin 14s linear infinite;filter:drop-shadow(0 0 8px rgba(232,255,74,.4));}
@keyframes iSpin{to{transform:rotateX(30deg) rotateY(360deg) rotateZ(60deg);}}

/* octa */
.octa-svg{width:90px;height:90px;animation:oSpin 8s linear infinite;filter:drop-shadow(0 0 8px rgba(74,240,255,.55));}
@keyframes oSpin{to{transform:rotateX(360deg) rotateY(360deg);}}

/* center card */
.cc-wrap{position:absolute;width:clamp(175px,27vw,330px);aspect-ratio:3/4;transform-style:preserve-3d;will-change:transform;z-index:5;}
.cc{width:100%;height:100%;border-radius:18px;overflow:hidden;position:relative;background:linear-gradient(135deg,#0d0d24,#111340,#0a1e50);box-shadow:0 60px 110px rgba(0,0,0,.9),0 0 0 1px rgba(255,255,255,.06) inset;}
.cc-orb{position:absolute;border-radius:50%;filter:blur(50px);pointer-events:none;}
.co1{width:70%;aspect-ratio:1;background:radial-gradient(circle,rgba(232,255,74,.28),transparent 70%);top:-15%;left:5%;}
.co2{width:85%;aspect-ratio:1;background:radial-gradient(circle,rgba(74,240,255,.14),transparent 70%);bottom:-20%;right:-8%;}
.cc-mid{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.cc-svg{width:52%;height:auto;filter:drop-shadow(0 0 22px rgba(232,255,74,.5));animation:ccSpin 10s linear infinite;}
@keyframes ccSpin{to{transform:rotateY(360deg) rotateX(20deg);}}
.cc-bot{position:absolute;bottom:1.8rem;left:1.5rem;right:1.5rem;}
.cc-tag{font-family:var(--ff-mono);font-size:.55rem;letter-spacing:.28em;text-transform:uppercase;color:var(--accent);margin-bottom:.3rem;}
.cc-name{font-family:var(--ff-head);font-size:1.8rem;letter-spacing:.05em;line-height:1;}
.cc-shine{position:absolute;inset:0;border-radius:18px;background:linear-gradient(135deg,rgba(255,255,255,.1) 0%,transparent 55%,rgba(255,255,255,.02) 100%);pointer-events:none;}

/* hero text */
.hero-txt{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:20;pointer-events:none;text-align:center;padding:2rem;}
.h-eye{font-family:var(--ff-mono);font-size:.68rem;letter-spacing:.4em;text-transform:uppercase;color:rgba(74,240,255,.7);margin-bottom:1.2rem;}
.h-name{font-family:var(--ff-head);font-size:clamp(3.5rem,11vw,10rem);letter-spacing:.04em;line-height:.9;color:var(--accent);text-shadow:0 0 80px rgba(232,255,74,.12);}
.h-role{font-family:var(--ff-head);font-size:clamp(1.1rem,2.5vw,2.5rem);letter-spacing:.15em;color:rgba(232,229,222,.5);margin-top:.5rem;}
.h-tag{font-size:.95rem;color:var(--muted);margin-top:1.4rem;max-width:480px;line-height:1.75;letter-spacing:.01em;}
.h-ctas{display:flex;gap:1rem;margin-top:2.2rem;pointer-events:all;flex-wrap:wrap;justify-content:center;}
.btn-pri{font-family:var(--ff-mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;padding:.8rem 2rem;background:var(--accent);color:var(--bg);border:none;border-radius:3px;cursor:pointer;transition:transform .15s,box-shadow .15s;font-weight:600;}
.btn-pri:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,255,74,.3);}
.btn-gh{font-family:var(--ff-mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;padding:.8rem 2rem;background:transparent;color:var(--text);border:1px solid var(--border);border-radius:3px;cursor:pointer;transition:border-color .2s,color .2s;}
.btn-gh:hover{border-color:var(--accent);color:var(--accent);}
.h-badge{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--ff-mono);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;padding:.4rem 1rem;border:1px solid rgba(74,240,255,.25);border-radius:2px;color:rgba(74,240,255,.8);margin-top:1.4rem;pointer-events:all;}
.h-dot{width:7px;height:7px;background:var(--cyan);border-radius:50%;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.scr-hint{position:absolute;bottom:3rem;left:50%;transform:translateX(-50%);font-family:var(--ff-mono);font-size:.58rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.18);display:flex;flex-direction:column;align-items:center;gap:.5rem;animation:bob 2s ease-in-out infinite;z-index:20;}
.scr-hint::after{content:'';width:1px;height:50px;background:linear-gradient(to bottom,rgba(232,255,74,.45),transparent);}
@keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(10px)}}

/* HUD */
.hud{position:fixed;top:5rem;right:2.5rem;z-index:200;font-family:var(--ff-mono);font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.2);text-align:right;line-height:2;pointer-events:none;transition:opacity .3s;}
.hud-v{color:var(--accent);font-family:var(--ff-head);font-size:1.2rem;letter-spacing:.05em;display:block;}
.hud-bar{width:70px;height:1.5px;background:rgba(255,255,255,.08);margin:3px 0 0 auto;border-radius:1px;overflow:hidden;}
.hud-f{height:100%;width:0;background:var(--accent);box-shadow:0 0 6px var(--accent);}

/* ══════════ ABOUT ══════════ */
.about-sec{padding:10rem 0 8rem;background:var(--bg2);border-top:1px solid var(--border);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;}
.a-photo-wrap{position:relative;}
.a-photo{width:100%;aspect-ratio:4/5;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,#111124,#0d2240);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;position:relative;}
.a-photo-ph{font-family:var(--ff-head);font-size:7rem;color:rgba(232,255,74,.1);letter-spacing:.1em;}
.a-decor{position:absolute;width:120px;height:120px;right:-28px;bottom:-28px;border:1px solid rgba(232,255,74,.14);border-radius:50%;}
.a-decor::before{content:'';position:absolute;inset:20px;border:1px solid rgba(232,255,74,.09);border-radius:50%;}
.a-text p{font-size:1rem;line-height:1.85;color:var(--muted);margin-bottom:1.4rem;}
.a-text p strong{color:var(--text);font-weight:700;}
.a-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:2.5rem;}
.a-stat{border-top:1px solid var(--border);padding-top:1rem;}
.a-num{font-family:var(--ff-head);font-size:2.8rem;color:var(--accent);line-height:1;}
.a-lbl{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-top:.3rem;}

/* ══════════ SKILLS ══════════ */
.skills-sec{padding:8rem 0;}
.sk-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
.sk-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.8rem;transition:border-color .25s,transform .25s,box-shadow .25s;position:relative;overflow:hidden;}
.sk-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .3s;background:linear-gradient(135deg,rgba(232,255,74,.04),transparent);}
.sk-card:hover{border-color:rgba(232,255,74,.3);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.4);}
.sk-card:hover::before{opacity:1;}
.sk-icon{font-size:1.8rem;margin-bottom:1rem;}
.sk-cat{font-family:var(--ff-head);font-size:1.3rem;letter-spacing:.05em;color:var(--accent);margin-bottom:1.2rem;}
.sk-tags{display:flex;flex-wrap:wrap;gap:.5rem;}
.sk-tag{font-family:var(--ff-mono);font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;padding:.28rem .65rem;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:3px;color:var(--muted);transition:border-color .2s,color .2s;}
.sk-card:hover .sk-tag{border-color:rgba(232,255,74,.2);color:var(--text);}

/* ══════════ PROJECTS ══════════ */
.proj-sec{padding:8rem 0;background:var(--bg2);border-top:1px solid var(--border);}
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem;}
.p-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:transform .25s,border-color .25s,box-shadow .25s;display:flex;flex-direction:column;}
.p-card:hover{transform:translateY(-6px);border-color:rgba(232,255,74,.22);box-shadow:0 30px 60px rgba(0,0,0,.5);}
.p-card.feat{grid-column:span 2;}
.p-thumb{aspect-ratio:16/9;background:linear-gradient(135deg,#0d1224,#0a1840);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.p-card.feat .p-thumb{aspect-ratio:2/1;}
.p-icon{font-size:3rem;opacity:.28;}
.p-glow{position:absolute;width:120px;height:120px;border-radius:50%;filter:blur(50px);}
.p-body{padding:1.5rem;flex:1;display:flex;flex-direction:column;}
.p-tags{display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:1rem;}
.ptag{font-family:var(--ff-mono);font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;padding:.22rem .55rem;border-radius:3px;border:1px solid;}
.t-r{color:rgba(74,240,255,.8);border-color:rgba(74,240,255,.22);background:rgba(74,240,255,.05);}
.t-n{color:rgba(100,220,100,.8);border-color:rgba(100,220,100,.22);background:rgba(100,220,100,.05);}
.t-ts{color:rgba(74,130,255,.9);border-color:rgba(74,130,255,.22);background:rgba(74,130,255,.05);}
.t-mg{color:rgba(80,210,100,.8);border-color:rgba(80,210,100,.22);background:rgba(80,210,100,.05);}
.t-pg{color:rgba(100,180,255,.8);border-color:rgba(100,180,255,.22);background:rgba(100,180,255,.05);}
.t-nx{color:rgba(220,220,220,.8);border-color:rgba(220,220,220,.18);background:rgba(220,220,220,.04);}
.t-aw{color:rgba(255,160,60,.8);border-color:rgba(255,160,60,.22);background:rgba(255,160,60,.05);}
.p-name{font-family:var(--ff-head);font-size:1.5rem;letter-spacing:.04em;margin-bottom:.5rem;}
.p-desc{font-size:.87rem;color:var(--muted);line-height:1.7;flex:1;}
.p-metric{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-top:.8rem;padding-top:.8rem;border-top:1px solid var(--border);}
.p-links{display:flex;gap:.7rem;margin-top:1.1rem;}
.p-link{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;padding:.38rem .85rem;border-radius:3px;border:1px solid var(--border);color:var(--muted);transition:border-color .2s,color .2s;display:inline-flex;align-items:center;gap:.35rem;}
.p-link:hover{border-color:var(--accent);color:var(--accent);}
.p-link.pri{background:rgba(232,255,74,.07);border-color:rgba(232,255,74,.28);color:var(--accent);}

/* ══════════ EXPERIENCE ══════════ */
.exp-sec{padding:8rem 0;}
.timeline{position:relative;padding-left:2rem;}
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,var(--accent),transparent);}
.tl-item{position:relative;padding:0 0 3.5rem 2.5rem;}
.tl-item::before{content:'';position:absolute;left:-2rem;top:.3rem;width:10px;height:10px;border-radius:50%;border:2px solid var(--accent);background:var(--bg);transform:translateX(50%);transition:background .2s;}
.tl-item:hover::before{background:var(--accent);}
.tl-date{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan);margin-bottom:.5rem;}
.tl-role{font-family:var(--ff-head);font-size:1.8rem;letter-spacing:.04em;line-height:1;margin-bottom:.2rem;}
.tl-co{font-size:.88rem;color:var(--muted);margin-bottom:1rem;}
.tl-pts{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
.tl-pts li{font-size:.88rem;color:var(--muted);line-height:1.65;padding-left:1.2rem;position:relative;}
.tl-pts li::before{content:'→';position:absolute;left:0;color:var(--accent);font-size:.75rem;}
.tl-stack{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem;}
.tl-badge{font-family:var(--ff-mono);font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;padding:.2rem .55rem;background:rgba(232,255,74,.05);border:1px solid rgba(232,255,74,.15);border-radius:3px;color:rgba(232,255,74,.7);}

/* ══════════ GITHUB ══════════ */
.gh-sec{padding:8rem 0;background:var(--bg2);border-top:1px solid var(--border);}
.contrib-wrap{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:2rem;margin-bottom:3rem;overflow-x:auto;}
.contrib-lbl{font-family:var(--ff-mono);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:1.2rem;}
.contrib-grid{display:flex;flex-direction:column;gap:3px;}
.contrib-row{display:flex;gap:3px;}
.contrib-cell{width:12px;height:12px;border-radius:2px;flex-shrink:0;}
.gh-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.repo-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.5rem;transition:border-color .25s,transform .2s;}
.repo-card:hover{border-color:rgba(232,255,74,.25);transform:translateY(-3px);}
.repo-name{font-family:var(--ff-mono);font-size:.85rem;color:var(--cyan);margin-bottom:.5rem;}
.repo-name span{color:var(--muted);}
.repo-desc{font-size:.84rem;color:var(--muted);line-height:1.65;margin-bottom:1rem;}
.repo-meta{display:flex;gap:1.2rem;font-family:var(--ff-mono);font-size:.62rem;color:var(--muted);}
.repo-star{color:var(--accent);}
.gh-cta{text-align:center;margin-top:3rem;}

/* ══════════ TESTIMONIALS ══════════ */
.testi-sec{padding:8rem 0;}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.t-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:2rem;position:relative;}
.t-q{font-family:var(--ff-head);font-size:5rem;line-height:.55;color:rgba(232,255,74,.1);position:absolute;top:1.5rem;left:1.8rem;}
.t-text{font-size:.9rem;color:var(--muted);line-height:1.8;margin-bottom:1.5rem;padding-top:1.5rem;}
.t-author{display:flex;align-items:center;gap:.8rem;border-top:1px solid var(--border);padding-top:1.2rem;}
.t-ava{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--cyan));display:flex;align-items:center;justify-content:center;font-family:var(--ff-head);font-size:1.1rem;color:var(--bg);flex-shrink:0;}
.t-name{font-size:.88rem;font-weight:700;color:var(--text);}
.t-role{font-family:var(--ff-mono);font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}

/* ══════════ BLOG ══════════ */
.blog-sec{padding:8rem 0;background:var(--bg2);border-top:1px solid var(--border);}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.b-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.8rem;transition:border-color .25s,transform .2s;display:flex;flex-direction:column;}
.b-card:hover{border-color:rgba(232,255,74,.2);transform:translateY(-3px);}
.b-date{font-family:var(--ff-mono);font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.8rem;}
.b-title{font-size:1rem;font-weight:700;line-height:1.4;margin-bottom:.8rem;color:var(--text);}
.b-exc{font-size:.84rem;color:var(--muted);line-height:1.7;flex:1;}
.b-more{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-top:1.1rem;display:flex;align-items:center;gap:.4rem;}
.b-more::after{content:'→';}

/* ══════════ CONTACT ══════════ */
.contact-sec{padding:10rem 0 8rem;}
.c-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;}
.c-info p{font-size:1rem;color:var(--muted);line-height:1.8;margin-bottom:2rem;}
.c-links{display:flex;flex-direction:column;gap:1rem;}
.c-link{display:flex;align-items:center;gap:1rem;padding:1rem 1.2rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;transition:border-color .2s,transform .2s;}
.c-link:hover{border-color:rgba(232,255,74,.3);transform:translateX(4px);}
.c-icon{font-size:1.1rem;width:24px;text-align:center;}
.c-lbl{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);display:block;}
.c-val{font-size:.9rem;color:var(--text);}
.c-form{display:flex;flex-direction:column;gap:1.2rem;}
.fg{display:flex;flex-direction:column;gap:.45rem;}
.flbl{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.finp,.ftxt{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:.9rem 1.1rem;color:var(--text);font-family:var(--ff-body);font-size:.9rem;outline:none;transition:border-color .2s;}
.finp:focus,.ftxt:focus{border-color:rgba(232,255,74,.4);}
.ftxt{min-height:140px;resize:vertical;}
.f-sub{font-family:var(--ff-mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;padding:1rem 2rem;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:700;transition:transform .15s,box-shadow .15s;align-self:flex-start;}
.f-sub:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,255,74,.28);}

/* ══════════ FOOTER ══════════ */
footer{padding:3rem 0;border-top:1px solid var(--border);}
.f-inner{display:flex;align-items:center;justify-content:space-between;}
.f-logo{font-family:var(--ff-head);font-size:1.5rem;color:var(--accent);}
.f-copy{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}
.f-soc{display:flex;gap:1.2rem;}
.f-soc a{font-family:var(--ff-mono);font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);transition:color .2s;}
.f-soc a:hover{color:var(--accent);}

/* ══════════ RESPONSIVE ══════════ */
@media(max-width:1024px){
  .sk-grid{grid-template-columns:repeat(2,1fr);}
  .proj-grid{grid-template-columns:1fr 1fr;}
  .p-card.feat{grid-column:span 2;}
  .gh-grid{grid-template-columns:repeat(2,1fr);}
  .testi-grid{grid-template-columns:1fr 1fr;}
  .blog-grid{grid-template-columns:1fr 1fr;}
}
@media(max-width:768px){
